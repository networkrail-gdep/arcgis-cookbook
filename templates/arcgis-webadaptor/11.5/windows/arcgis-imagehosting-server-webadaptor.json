{
    "arcgis": {
        "version": "11.5",
        "run_as_user": "gdepadmin",
        "run_as_password": "<run_as_password>",
        "configure_windows_firewall": true,
        "repository": {
            "archives": "C:\\Software\\Archives",
            "setups": "C:\\Software\\Setups"
        },
        "iis": {
            "keystore_file": "C:\\Temp\\keystore.pfx",
            "keystore_password": "<keystore_password>",
            "replace_https_binding": true
        },
        "server": {
            "url": "https://<image_server_private_ip>:6443/arcgis",
            "wa_url": "https://devgis.networkrail.co.uk/image",
            "admin_username": "arcgisadmin",
            "admin_password": "<server_admin_password>",
            "wa_name": "image"
        },
        "web_adaptor": {
            "install_system_requirements": true,
            "dotnet_setup_path": "C:\\Software\\Archives\\dotnet-hosting-8.0.11-win.exe",
            "web_deploy_setup_path": "C:\\Software\\Archives\\WebDeploy_amd64_en-US.msi"
        }
    },
    "run_list": [
        "recipe[arcgis-enterprise::system]",
        "recipe[esri-iis]",
        "recipe[arcgis-enterprise::server_wa]"
    ]
}
